[sub_resource type="Shader" id="Shader_Vignette"]
code = "shader_type canvas_item;
void fragment() {
	vec2 uv = UV - vec2(0.5);
	float d = length(uv);
	float vig = smoothstep(0.45, 0.88, d);
	COLOR = vec4(0.0, 0.0, 0.0, vig * 0.5);
}
"

